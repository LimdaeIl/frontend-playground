    "viewHtml": "<!-- Copyright start\n  MIT License\n  Copyright (c) 2026\n  Copyright end -->\n\n<script src=\"widgets\/installed\/kacbc-1.0.0\/widgetAssets\/js\/widgetUtility.service.js\"><\/script>\n\n<style type=\"text\/css\">\n@keyframes kacbc-sky-shift {\n  0%   { background-position: 0% 50%; }\n  50%  { background-position: 100% 50%; }\n  100% { background-position: 0% 50%; }\n}\n@keyframes kacbc-scan {\n  0%   { transform: translateX(-120%); opacity: 0; }\n  10%  { opacity: 1; }\n  90%  { opacity: 1; }\n  100% { transform: translateX(420%); opacity: 0; }\n}\n@keyframes kacbc-float {\n  0%, 100% { transform: translateY(0px); }\n  50% { transform: translateY(-4px); }\n}\n@keyframes kacbc-glow {\n  0%, 100% { box-shadow: 0 0 10px rgba(96,165,250,0.24); }\n  50% { box-shadow: 0 0 28px rgba(125,211,252,0.34); }\n}\n@keyframes kacbc-pulse {\n  0%, 100% { opacity: 0.65; transform: scale(1); }\n  50% { opacity: 1; transform: scale(1.14); }\n}\n@keyframes kacbc-route {\n  0% { stroke-dashoffset: 140; }\n  100% { stroke-dashoffset: 0; }\n}\n@keyframes kacbc-accent {\n  0% { background-position: -100% 0; }\n  100% { background-position: 200% 0; }\n}\n\n.kacbc-wrap {\n  position: relative;\n  padding: 0 !important;\n  overflow: hidden;\n  border-radius: 16px;\n}\n\n.kacbc-banner {\n  position: relative;\n  display: flex;\n  align-items: stretch;\n  min-height: 130px;\n  background:\n    radial-gradient(circle at 18% 18%, rgba(125,211,252,0.16), transparent 22%),\n    radial-gradient(circle at 82% 22%, rgba(96,165,250,0.18), transparent 20%),\n    linear-gradient(120deg, #02101f 0%, #072447 24%, #0b3a73 48%, #082b55 72%, #02101f 100%);\n  background-size: 220% 220%;\n  animation: kacbc-sky-shift 18s ease infinite;\n  overflow: hidden;\n  border: 1px solid rgba(125,211,252,0.14);\n  border-radius: 16px;\n}\n\n.kacbc-banner::before {\n  content: '';\n  position: absolute;\n  inset: 0;\n  background-image:\n    linear-gradient(rgba(191,219,254,0.03) 1px, transparent 1px),\n    linear-gradient(90deg, rgba(191,219,254,0.03) 1px, transparent 1px);\n  background-size: 32px 32px;\n  pointer-events: none;\n}\n\n.kacbc-banner::after {\n  content: '';\n  position: absolute;\n  inset: 0;\n  background: linear-gradient(90deg, transparent, rgba(125,211,252,0.08), transparent);\n  transform: translateX(-100%);\n  animation: kacbc-scan 10s ease-in-out infinite;\n  pointer-events: none;\n}\n\n.kacbc-collapse-btn {\n  position: absolute;\n  top: 10px;\n  right: 10px;\n  z-index: 10;\n  width: 22px;\n  height: 22px;\n  border-radius: 50%;\n  border: 1px solid rgba(191,219,254,0.18);\n  background: rgba(2,16,31,0.55);\n  color: rgba(219,234,254,0.7);\n  cursor: pointer;\n  padding: 0;\n}\n\n.kacbc-content {\n  position: relative;\n  z-index: 2;\n  display: flex;\n  align-items: center;\n  width: 100%;\n  padding: 18px 22px;\n}\n\n.kacbc-logo-section {\n  flex: 0 0 auto;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  padding-right: 24px;\n  border-right: 1px solid rgba(191,219,254,0.14);\n  margin-right: 24px;\n}\n\n.kacbc-mark-wrap {\n  position: relative;\n  width: 82px;\n  height: 82px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  animation: kacbc-float 5s ease-in-out infinite;\n}\n\n.kacbc-mark-ring {\n  position: absolute;\n  inset: 0;\n  border-radius: 50%;\n  border: 1px dashed rgba(125,211,252,0.18);\n}\n\n.kacbc-mark-core {\n  position: relative;\n  width: 64px;\n  height: 64px;\n  border-radius: 50%;\n  background: radial-gradient(circle at 28% 28%, #93c5fd 0%, #3b82f6 40%, #0a2540 100%);\n  animation: kacbc-glow 3s ease-in-out infinite;\n  overflow: hidden;\n}\n\n.kacbc-mark-core::before {\n  content: '';\n  position: absolute;\n  left: 16px;\n  top: 28px;\n  width: 34px;\n  height: 8px;\n  border-radius: 999px;\n  background: linear-gradient(90deg, rgba(255,255,255,0.96), rgba(191,219,254,0.25));\n  transform: rotate(-22deg);\n}\n\n.kacbc-logo-label {\n  margin-top: 8px;\n  font-size: 8px;\n  letter-spacing: 0.34em;\n  text-transform: uppercase;\n  font-weight: 700;\n  color: rgba(191,219,254,0.7);\n}\n\n.kacbc-brand-section {\n  flex: 1;\n  display: flex;\n  flex-direction: column;\n  justify-content: center;\n  min-width: 0;\n}\n\n.kacbc-org-name {\n  font-size: 24px;\n  font-weight: 800;\n  letter-spacing: 0.05em;\n  color: #f8fbff;\n  line-height: 1.08;\n}\n\n.kacbc-center-name {\n  margin-top: 3px;\n  font-size: 11px;\n  text-transform: uppercase;\n  letter-spacing: 0.3em;\n  color: rgba(191,219,254,0.82);\n  font-weight: 700;\n}\n\n.kacbc-divider {\n  width: 52px;\n  height: 2px;\n  border-radius: 999px;\n  margin: 9px 0;\n  background: linear-gradient(90deg, #7dd3fc, rgba(125,211,252,0.12));\n}\n\n.kacbc-tagline {\n  font-size: 12px;\n  color: rgba(219,234,254,0.78);\n  font-style: italic;\n  letter-spacing: 0.03em;\n}\n\n.kacbc-seal-section {\n  flex: 0 0 auto;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  gap: 7px;\n  padding: 0 28px;\n  margin-left: 8px;\n  border-left: 1px solid rgba(191,219,254,0.12);\n  border-right: 1px solid rgba(191,219,254,0.12);\n}\n\n.kacbc-route-card {\n  width: 78px;\n  height: 74px;\n  border-radius: 18px;\n  border: 1px solid rgba(147,197,253,0.16);\n  background: rgba(2,16,31,0.26);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n.kacbc-route-svg path {\n  stroke-dasharray: 140;\n  animation: kacbc-route 2.4s ease-out forwards;\n}\n\n.kacbc-year {\n  font-size: 9px;\n  letter-spacing: 0.25em;\n  font-weight: 700;\n  color: rgba(191,219,254,0.62);\n}\n\n.kacbc-status {\n  display: flex;\n  align-items: center;\n  gap: 6px;\n  font-size: 8.5px;\n  letter-spacing: 0.14em;\n  color: rgba(125,211,252,0.92);\n  font-weight: 700;\n}\n\n.kacbc-status-dot,\n.kacbc-badge-dot,\n.kacbc-live-dot {\n  border-radius: 50%;\n  animation: kacbc-pulse 2s ease-in-out infinite;\n}\n\n.kacbc-status-dot {\n  width: 7px;\n  height: 7px;\n  background: #7dd3fc;\n  box-shadow: 0 0 10px rgba(125,211,252,0.55);\n}\n\n.kacbc-products-section {\n  flex: 0 0 auto;\n  display: flex;\n  flex-direction: column;\n  align-items: flex-start;\n  gap: 6px;\n  padding-left: 24px;\n}\n\n.kacbc-badge,\n.kacbc-live-badge {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  padding: 4px 12px 4px 9px;\n  border-radius: 20px;\n  white-space: nowrap;\n  background: rgba(2,16,31,0.34);\n}\n\n.kacbc-badge {\n  border: 1px solid rgba(125,211,252,0.22);\n}\n\n.kacbc-badge-dot {\n  width: 6px;\n  height: 6px;\n  background: #93c5fd;\n}\n\n.kacbc-badge-text {\n  font-size: 9.5px;\n  font-weight: 700;\n  letter-spacing: 0.07em;\n  color: rgba(239,246,255,0.92);\n}\n\n.kacbc-live-badge {\n  border: 1px solid rgba(52,211,153,0.28);\n  background: rgba(52,211,153,0.08);\n}\n\n.kacbc-live-dot {\n  width: 7px;\n  height: 7px;\n  background: #34d399;\n}\n\n.kacbc-live-badge span {\n  font-size: 9px;\n  font-weight: 800;\n  letter-spacing: 0.18em;\n  color: rgba(110,231,183,0.95);\n}\n\n.kacbc-accent-bar {\n  position: absolute;\n  left: 0;\n  right: 0;\n  bottom: 0;\n  height: 3px;\n  background: linear-gradient(90deg, #02101f 0%, #60a5fa 24%, #7dd3fc 50%, #60a5fa 76%, #02101f 100%);\n  background-size: 200% 100%;\n  animation: kacbc-accent 5s linear infinite;\n}\n\n.kacbc-collapsed-bar {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n  padding: 10px 16px;\n  border-radius: 12px;\n  background: linear-gradient(90deg, #041323, #0a305b, #041323);\n  border: 1px solid rgba(125,211,252,0.16);\n  cursor: pointer;\n}\n\n.kacbc-collapsed-mark {\n  width: 24px;\n  height: 24px;\n  border-radius: 50%;\n  background: radial-gradient(circle at 30% 30%, #93c5fd, #2563eb 62%, #0a2540 100%);\n  position: relative;\n}\n\n.kacbc-collapsed-mark::after {\n  content: '';\n  position: absolute;\n  left: 6px;\n  top: 11px;\n  width: 12px;\n  height: 4px;\n  border-radius: 999px;\n  background: linear-gradient(90deg, rgba(255,255,255,0.95), rgba(191,219,254,0.3));\n  transform: rotate(-24deg);\n}\n\n.kacbc-collapsed-bar span {\n  font-size: 12px;\n  font-weight: 700;\n  color: rgba(239,246,255,0.88);\n  letter-spacing: 0.07em;\n}\n<\/style>\n\n<div class=\"widget widget-container kacbc-wrap\">\n  <div class=\"kacbc-banner\" data-ng-hide=\"collapsed\">\n    <div class=\"kacbc-accent-bar\"><\/div>\n    <button class=\"kacbc-collapse-btn\" data-ng-click=\"collapsed = true\" title=\"Collapse\">\n      <span class=\"fa fa-caret-up\"><\/span>\n    <\/button>\n\n    <div class=\"kacbc-content\">\n      <div class=\"kacbc-logo-section\" data-ng-if=\"config.showWingMark !== false\">\n        <div class=\"kacbc-mark-wrap\">\n          <div class=\"kacbc-mark-ring\"><\/div>\n          <div class=\"kacbc-mark-core\"><\/div>\n        <\/div>\n        <div class=\"kacbc-logo-label\">Korean Air<\/div>\n      <\/div>\n\n      <div class=\"kacbc-brand-section\">\n        <div class=\"kacbc-org-name\">{{ config.orgName || 'Korean Air' }}<\/div>\n        <div class=\"kacbc-center-name\">{{ config.centerName || 'Executive Briefing Lounge' }}<\/div>\n        <div class=\"kacbc-divider\"><\/div>\n        <div class=\"kacbc-tagline\">{{ config.tagline || 'Elevated journeys through resilient operations' }}<\/div>\n      <\/div>\n\n      <div class=\"kacbc-seal-section\">\n        <div class=\"kacbc-route-card\">\n          <svg class=\"kacbc-route-svg\" width=\"58\" height=\"46\" viewBox=\"0 0 58 46\" xmlns=\"http:\/\/www.w3.org\/2000\/svg\">\n            <circle cx=\"11\" cy=\"31\" r=\"3.5\" fill=\"#7dd3fc\"\/>\n            <circle cx=\"47\" cy=\"14\" r=\"3.5\" fill=\"#bfdbfe\"\/>\n            <path d=\"M11 31 C18 12, 33 11, 47 14\" fill=\"none\" stroke=\"#93c5fd\" stroke-width=\"2.2\" stroke-linecap=\"round\"\/>\n            <path d=\"M34 9 L47 14 L37 20\" fill=\"none\" stroke=\"#dbeafe\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"\/>\n          <\/svg>\n        <\/div>\n        <div class=\"kacbc-year\">{{ config.hubCode || 'ICN' }} \u00b7 {{ currentYear }}<\/div>\n        <div class=\"kacbc-status\">\n          <div class=\"kacbc-status-dot\"><\/div>\n          <span>{{ config.serviceMode || 'LIVE STATUS' }}<\/span>\n        <\/div>\n      <\/div>\n\n      <div class=\"kacbc-products-section\">\n        <div class=\"kacbc-badge\">\n          <div class=\"kacbc-badge-dot\"><\/div>\n          <span class=\"kacbc-badge-text\">Passenger Operations<\/span>\n        <\/div>\n        <div class=\"kacbc-badge\">\n          <div class=\"kacbc-badge-dot\"><\/div>\n          <span class=\"kacbc-badge-text\">FortiSOAR Automation<\/span>\n        <\/div>\n        <div class=\"kacbc-live-badge\">\n          <div class=\"kacbc-live-dot\"><\/div>\n          <span>BOARDING READY<\/span>\n        <\/div>\n      <\/div>\n    <\/div>\n  <\/div>\n\n  <div class=\"kacbc-collapsed-bar\" data-ng-show=\"collapsed\" data-ng-click=\"collapsed = false\">\n    <div class=\"kacbc-collapsed-mark\" data-ng-if=\"config.showWingMark !== false\"><\/div>\n    <span>{{ config.orgName || 'Korean Air' }} \u00b7 {{ config.centerName || 'Executive Briefing Lounge' }}<\/span>\n    <span class=\"fa fa-caret-down\" style=\"margin-left:auto;color:rgba(191,219,254,0.65);\"><\/span>\n  <\/div>\n<\/div>\n",
    "editHtml": "<!-- Copyright start\n  MIT License\n  Copyright (c) 2026\n  Copyright end -->\n\n<script src=\"widgets\/installed\/kacbc-1.0.0\/widgetAssets\/js\/widgetUtility.service.js\"><\/script>\n\n<style>\n.kacbc-edit-preview {\n  background: linear-gradient(135deg, #021326, #0a2b54, #08203d);\n  border-radius: 12px;\n  padding: 14px 18px;\n  display: flex;\n  align-items: center;\n  gap: 14px;\n  margin-bottom: 16px;\n  border: 1px solid rgba(108, 183, 255, 0.24);\n}\n.kacbc-edit-mark {\n  width: 40px;\n  height: 40px;\n  border-radius: 50%;\n  background: radial-gradient(circle at 30% 30%, #7dd3fc, #2563eb 65%, #0b1120 100%);\n  box-shadow: 0 0 18px rgba(59, 130, 246, 0.35);\n  position: relative;\n  overflow: hidden;\n}\n.kacbc-edit-mark::after {\n  content: '';\n  position: absolute;\n  left: 10px;\n  top: 18px;\n  width: 22px;\n  height: 6px;\n  border-radius: 999px;\n  background: linear-gradient(90deg, rgba(255,255,255,0.9), rgba(191,219,254,0.3));\n  transform: rotate(-24deg);\n}\n.kacbc-edit-preview-text { display: flex; flex-direction: column; gap: 3px; }\n.kacbc-edit-preview-org { font-size: 15px; font-weight: 800; color: #fff; letter-spacing: 0.05em; }\n.kacbc-edit-preview-ctr { font-size: 10px; font-weight: 700; color: rgba(191,219,254,0.82); letter-spacing: 0.28em; text-transform: uppercase; }\n<\/style>\n\n<form data-ng-submit=\"save()\" class=\"noMargin\" name=\"editKacbcForm\" novalidate>\n  <div class=\"modal-header\">\n    <h3 class=\"modal-title col-md-9\">Korean Air \ubc30\ub108 \uc124\uc815<\/h3>\n    <button type=\"button\" class=\"close\" data-ng-click=\"cancel()\" data-dismiss=\"modal\"\n      aria-label=\"Close\" id=\"close-edit-widget-form-btn\">\n      <div aria-hidden=\"true\" class=\"version-button\">+<\/div>\n    <\/button>\n  <\/div>\n\n  <div class=\"modal-body\">\n    <div class=\"kacbc-edit-preview\">\n      <div class=\"kacbc-edit-mark\"><\/div>\n      <div class=\"kacbc-edit-preview-text\">\n        <div class=\"kacbc-edit-preview-org\">{{ config.orgName }}<\/div>\n        <div class=\"kacbc-edit-preview-ctr\">{{ config.centerName }}<\/div>\n      <\/div>\n    <\/div>\n\n    <div class=\"form-group\">\n      <label class=\"control-label\">\uc870\uc9c1\uba85<\/label>\n      <input type=\"text\" class=\"form-control\"\n        data-ng-model=\"config.orgName\" placeholder=\"Korean Air\">\n    <\/div>\n\n    <div class=\"form-group\">\n      <label class=\"control-label\">\uc13c\ud130\uba85<\/label>\n      <input type=\"text\" class=\"form-control\"\n        data-ng-model=\"config.centerName\" placeholder=\"Executive Briefing Lounge\">\n    <\/div>\n\n    <div class=\"form-group\">\n      <label class=\"control-label\">\ud0dc\uadf8\ub77c\uc778<\/label>\n      <input type=\"text\" class=\"form-control\"\n        data-ng-model=\"config.tagline\" placeholder=\"Elevated journeys through resilient operations\">\n    <\/div>\n\n    <div class=\"form-group\">\n      <label class=\"control-label\">\ud5c8\ube0c \ucf54\ub4dc<\/label>\n      <input type=\"text\" class=\"form-control\"\n        data-ng-model=\"config.hubCode\" placeholder=\"ICN\">\n    <\/div>\n\n    <div class=\"form-group\">\n      <label class=\"control-label\">\uc0c1\ud0dc \ubc43\uc9c0 \ubb38\uad6c<\/label>\n      <input type=\"text\" class=\"form-control\"\n        data-ng-model=\"config.serviceMode\" placeholder=\"LIVE STATUS\">\n    <\/div>\n\n    <div class=\"form-group\">\n      <label class=\"control-label\">\ud45c\uc2dc \uc635\uc158<\/label>\n      <div style=\"display:flex; gap:24px; margin-top:6px;\">\n        <label style=\"display:flex;align-items:center;gap:7px;margin:0;font-weight:400;cursor:pointer;\">\n          <input type=\"checkbox\" data-ng-model=\"config.showWingMark\">\n          <span>\uc6d0\ud615 \uc719 \ub9c8\ud06c \ud45c\uc2dc<\/span>\n        <\/label>\n      <\/div>\n    <\/div>\n  <\/div>\n\n  <div class=\"modal-footer\">\n    <button id=\"edit-widget-save\" type=\"submit\" class=\"btn btn-sm btn-primary\">\n      <i class=\"icon icon-check margin-right-sm\"><\/i>{{ viewWidgetVars.BTN_SAVE || 'Save' }}\n    <\/button>\n    <button id=\"edit-widget-cancel\" type=\"button\" class=\"btn btn-sm btn-default\" data-ng-click=\"cancel()\">\n      <i class=\"icon icon-close margin-right-sm\"><\/i>{{ viewWidgetVars.BTN_CLOSE || 'Close' }}\n    <\/button>\n  <\/div>\n<\/form>\n",
    "viewController": "\/* Copyright start\n  MIT License\n  Copyright (c) 2026\n  Copyright end *\/\n'use strict';\n(function () {\n  angular\n    .module('cybersponse')\n    .controller('kacbc100Ctrl', kacbc100Ctrl);\n\n  kacbc100Ctrl.$inject = [\n    '$scope', 'widgetUtilityService', 'config', '$rootScope'\n  ];\n\n  function kacbc100Ctrl($scope, widgetUtilityService, config, $rootScope) {\n\n    $scope.config = config;\n    $scope.themeId = $rootScope.theme ? $rootScope.theme.id : 'dark';\n    $scope.currentYear = new Date().getFullYear();\n\n    function _handleTranslations() {\n      widgetUtilityService.checkTranslationMode($scope.$parent.model.type).then(function () {\n        $scope.viewWidgetVars = {\n          LABEL_REFRESH: widgetUtilityService.translate('kacbc.LABEL_REFRESH') || 'Refresh'\n        };\n      });\n    }\n\n    $scope.init = function () {\n      _handleTranslations();\n    };\n\n    $scope.init();\n  }\n})();\n",
    "editController": "\/* Copyright start\n  MIT License\n  Copyright (c) 2026\n  Copyright end *\/\n'use strict';\n(function () {\n  angular\n    .module('cybersponse')\n    .controller('editKacbc100Ctrl', editKacbc100Ctrl);\n\n  editKacbc100Ctrl.$inject = [\n    '$scope', '$uibModalInstance', 'config', 'widgetUtilityService', '$timeout'\n  ];\n\n  function editKacbc100Ctrl($scope, $uibModalInstance, config, widgetUtilityService, $timeout) {\n\n    $scope.cancel = cancel;\n    $scope.save = save;\n\n    $scope.config = angular.extend({\n      orgName: 'Korean Air',\n      centerName: 'Executive Briefing Lounge',\n      tagline: 'Elevated journeys through resilient operations',\n      hubCode: 'ICN',\n      serviceMode: 'LIVE STATUS',\n      showWingMark: true\n    }, config);\n\n    function _handleTranslations() {\n      var wv = widgetUtilityService.getWidgetNameVersion(\n        $scope.$resolve.widget, $scope.$resolve.widgetBasePath);\n      if (wv) {\n        widgetUtilityService.checkTranslationMode(wv).then(function () {\n          $scope.viewWidgetVars = {\n            'BTN_CLOSE': widgetUtilityService.translate('kacbc.BTN_CLOSE') || 'Close',\n            'BTN_SAVE': widgetUtilityService.translate('kacbc.BTN_SAVE') || 'Save'\n          };\n        });\n      } else {\n        $timeout(function () { $scope.cancel(); });\n      }\n    }\n\n    _handleTranslations();\n\n    function cancel() { $uibModalInstance.dismiss('cancel'); }\n\n    function save() {\n      if ($scope.editKacbcForm.$invalid) {\n        $scope.editKacbcForm.$setTouched();\n        return;\n      }\n      $uibModalInstance.close($scope.config);\n    }\n  }\n})();\n",
